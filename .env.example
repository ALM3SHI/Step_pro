# =====================================================================
# Copy to .env.local for local dev. Add the same keys in
# Vercel -> Project -> Settings -> Environment Variables.
# =====================================================================

# --- Supabase: Project Settings -> API -------------------------------
# Safe to expose. NEXT_PUBLIC_ variables are compiled into browser JS.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key

# SECRET. Bypasses every row-level security policy.
# - never prefix with NEXT_PUBLIC_
# - never import into a client component
# - in Vercel, leave "Sensitive" enabled so it cannot be read back
# If this ever leaks, rotate it in Supabase -> Settings -> API immediately.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key

# --- Storage ---------------------------------------------------------
# Created by supabase/migrations/0005_storage.sql. Private bucket;
# playback uses short-lived signed URLs.
# Referenced in code as AUDIO_BUCKET — change both if you rename it.
# SUPABASE_AUDIO_BUCKET=listening-audio

# --- LLM (Mode B only — not needed for the hybrid workflow) ----------
# gemini | openai | anthropic | ollama
LLM_PROVIDER=gemini
# LLM_MODEL=gemini-1.5-flash
GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434/v1

# --- Admin panel -----------------------------------------------------
# Gates /admin and, more importantly, every content-writing server
# action. WITHOUT THIS THE PANEL IS CLOSED TO EVERYONE — it fails shut,
# never open, so an unconfigured deployment cannot expose the bank.
# Server-only: never prefix with NEXT_PUBLIC_.
ADMIN_PASSWORD=

# Optional. Signs the admin session cookie; derived from ADMIN_PASSWORD
# when omitted. Set it explicitly to invalidate all sessions without
# changing the password, or to rotate on a schedule.
# ADMIN_SESSION_SECRET=
